{
  "name": "cancip",
  "version": "1.37",
  "private": true,
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck && node scripts/prepare-release-output.mjs && node esbuild.config.mjs production",
    "check": "tsc --noEmit --skipLibCheck",
    "smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-cancip-smoke.ps1",
    "smoke:full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-cancip-smoke.ps1 -Full",
    "smoke:write": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-cancip-smoke.ps1 -Write"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "esbuild": "^0.21.5",
    "obsidian": "1.12.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "onnxruntime-web": "^1.27.0",
    "pinyin-pro": "^3.28.1"
  }
}
