{
  "name": "cancip",
  "version": "2.11.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "verify:source-parity": "node scripts/verify-source-runtime-parity.mjs",
    "build": "npm run verify:source-parity && tsc --noEmit --skipLibCheck && node scripts/prepare-release-output.mjs && node esbuild.config.mjs production",
    "check": "tsc --noEmit --skipLibCheck",
    "smoke": "pwsh -NoProfile -File scripts/run-cancip-smoke.ps1",
    "smoke:full": "pwsh -NoProfile -File scripts/run-cancip-smoke.ps1 -Full",
    "smoke:mobile": "pwsh -NoProfile -File scripts/run-cancip-smoke.ps1 -Mobile",
    "smoke:ui": "pwsh -NoProfile -File scripts/run-cancip-smoke.ps1 -Case programmatic.ui-button",
    "verify": "npm run check && npm run build && npm run smoke:mobile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "esbuild": "^0.21.5",
    "obsidian": "1.12.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "onnxruntime-web": "^1.27.0",
    "pinyin-pro": "^3.28.1"
  }
}
