{
  "schema": 1,
  "description": "Reusable Cancip smoke/regression cases for prompt economy, routing, tool access, and mobile-safe command bus behavior. Default run is read-only and no API.",
  "budgets": {
    "memoryModePromptChars": 1800,
    "memoryContextChars": 1700,
    "answerModePromptChars": 800,
    "capabilityModePromptChars": 2600,
    "implementationModePromptChars": 4200,
    "commandMs": 7000
  },
  "promptCases": [
    {
      "id": "memory.identity.zh",
      "prompt": "我是谁",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 1800,
        "maxContextChars": 1700,
        "maxActions": 0,
        "forbidCommands": [
          "cancip.tools.index",
          "cancip.skills.list",
          "github.help",
          "cancip.automation.templates"
        ],
        "policyFalse": [
          "includeToolCatalog",
          "includeAutoSkills",
          "includePluginMemory",
          "includeProjectMemory",
          "includeDetailedRules"
        ]
      }
    },
    {
      "id": "memory.profile.variant",
      "prompt": "你记得我什么",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 1800,
        "maxContextChars": 1900,
        "maxActions": 0,
        "forbidCommands": [
          "cancip.tools.index",
          "cancip.skills.list",
          "github.help",
          "cancip.automation.templates"
        ],
        "policyFalse": [
          "includeToolCatalog",
          "includeAutoSkills",
          "includePluginMemory",
          "includeProjectMemory",
          "includeDetailedRules"
        ]
      }
    },
    {
      "id": "memory.preferences.zh",
      "prompt": "我的输出偏好是什么",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 1800,
        "maxContextChars": 1900,
        "maxActions": 0,
        "forbidCommands": [
          "cancip.tools.index",
          "cancip.skills.list",
          "github.help",
          "cancip.automation.templates"
        ]
      }
    },
    {
      "id": "skill.discovery.pdf",
      "prompt": "有哪些 skill 可以读 pdf 和 excel",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog",
          "includeAutoSkills"
        ],
        "policyFalse": [
          "includePluginMemory"
        ]
      }
    },
    {
      "id": "plugin.list.zh",
      "prompt": "列出已启用的 obsidian 插件",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog",
          "includeAutoSkills"
        ]
      }
    },
    {
      "id": "plugin.capabilities.notedraw",
      "prompt": "NoteDraw 插件能不能做涂鸦高亮，先查能力和可用路线",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog",
          "includePluginMemory"
        ]
      }
    },
    {
      "id": "plugin.generic-route.new-plugin",
      "prompt": "新装插件应该怎么自动接入 Cancip，先查插件 API 和命令路线",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog",
          "includePluginMemory"
        ]
      }
    },
    {
      "id": "ob.current-view",
      "prompt": "查看当前 ob 页面和当前文件",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog"
        ]
      }
    },
    {
      "id": "automation.templates",
      "prompt": "自动化模板有哪些",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog"
        ]
      }
    },
    {
      "id": "session.history.route",
      "prompt": "分析 session-2026-07-04T13-28-56Z 这次为什么没完成",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog"
        ]
      }
    },
    {
      "id": "attachment.help.mobile",
      "prompt": "手机附件怎么导入并发给 ai",
      "expect": {
        "intent": "informational",
        "maxModePromptChars": 2600,
        "maxActions": 0,
        "policyTrue": [
          "includeToolCatalog"
        ]
      }
    },
    {
      "id": "tts.read-active.execute",
      "prompt": "朗读当前文件（用ob朗读命令）",
      "expect": {
        "intent": "implementation",
        "maxModePromptChars": 4200,
        "maxActions": 0,
        "policyTrue": [
          "compactStateChange",
          "includeToolCatalog"
        ],
        "policyFalse": [
          "includeToolProtocol",
          "includeDetailedRules"
        ]
      }
    },
    {
      "id": "vault.write.markdown-syntax-route",
      "prompt": "根目录建一个 md 常见语法文件并验证",
      "expect": {
        "intent": "implementation",
        "maxModePromptChars": 4200,
        "policyTrue": [
          "compactStateChange",
          "includeToolCatalog"
        ],
        "policyFalse": [
          "includeToolProtocol",
          "includeDetailedRules"
        ]
      }
    },
    {
      "id": "config.update.route",
      "prompt": "把 Cancip 最大工具迭代数改成 8 并读回配置确认",
      "expect": {
        "intent": "implementation",
        "maxModePromptChars": 4200,
        "policyTrue": [
          "includeToolProtocol",
          "includeDetailedRules"
        ]
      }
    },
    {
      "id": "ob.command.tabs.route",
      "prompt": "用 Obsidian 命令或工作区能力关闭右侧非固定标签页并校验",
      "expect": {
        "intent": "implementation",
        "maxModePromptChars": 4200,
        "policyTrue": [
          "includeToolProtocol",
          "includeDetailedRules"
        ]
      }
    },
    {
      "id": "implementation.self-repair",
      "prompt": "修复 cancip 侧边栏结论重复并验证",
      "expect": {
        "intent": "implementation",
        "maxModePromptChars": 4200,
        "policyTrue": [
          "includeToolProtocol",
          "includeDetailedRules"
        ]
      }
    }
  ],
  "commandCases": [
    {
      "id": "command.tools.index",
      "command": "cancip.tools.index",
      "args": {},
      "expect": {
        "contains": ["动作路由索引"],
        "maxMs": 2000
      }
    },
    {
      "id": "command.memory.read.profile",
      "action": { "type": "read", "path": "AI/Cancip/Memory/PROFILE.md", "maxChars": 1600 },
      "expect": {
        "contains": ["姓名/称呼", "GitHub"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.skills.list",
      "command": "cancip.skills.list",
      "args": {},
      "expect": {
        "containsAny": ["Skill", "skills", "Obsidian", "PDF", "Hermes"],
        "maxMs": 8000
      }
    },
    {
      "id": "command.skills.read",
      "command": "cancip.skills.read",
      "args": { "query": "obsidian" },
      "expect": {
        "containsAny": ["Obsidian", "vault", "note", "笔记"],
        "maxMs": 5000
      }
    },
    {
      "id": "command.plugins.installed",
      "command": "cancip.installedPlugins",
      "args": { "includeDisabled": false },
      "expect": {
        "containsAny": ["plugin", "插件", "cancip", "enabled"],
        "maxMs": 5000
      }
    },
    {
      "id": "command.plugins.capabilities.notedraw",
      "command": "cancip.pluginCapabilities",
      "args": { "query": "notdraw 涂鸦 高亮", "includeDisabled": true, "includeApi": true, "includeFiles": true, "commandLimit": 20 },
      "expect": {
        "containsAny": ["NoteDraw", "notedraw", "toggle-draw-mode", "涂鸦"],
        "maxMs": 5000
      }
    },
    {
      "id": "command.plugins.capabilities.pdftion",
      "command": "cancip.pluginCapabilities",
      "args": { "query": "pdftion pdf 批注 高亮", "includeDisabled": true, "includeApi": true, "includeFiles": false, "commandLimit": 20 },
      "expect": {
        "containsAny": ["Pdftion", "pdftion", "export-annotations", "PDF"],
        "maxMs": 5000
      }
    },
    {
      "id": "command.plugins.route.notedraw",
      "command": "cancip.pluginRoute",
      "args": { "query": "notedraw 涂鸦 高亮", "includeApi": true, "commandLimit": 20 },
      "expect": {
        "containsAny": ["Generic plugin route", "pluginAction", "NoteDraw", "notedraw"],
        "maxMs": 6000
      }
    },
    {
      "id": "command.annotate.help",
      "command": "cancip.annotate.help",
      "args": { "maxChars": 6000 },
      "expect": {
        "contains": ["cancip.annotate.note", "cancip.annotate.pdf", "Non-visual", "pluginRoute"],
        "maxMs": 7000
      }
    },
    {
      "id": "command.annotate.note.status",
      "command": "cancip.annotate.note",
      "args": { "op": "status" },
      "expect": {
        "contains": ["NoteDraw annotation status", "directStorage", "ops:"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.annotate.pdf.status",
      "command": "cancip.annotate.pdf",
      "args": { "op": "status" },
      "expect": {
        "contains": ["Pdftion annotation status", "directStorage", "non-visual"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.study.help",
      "command": "cancip.study.help",
      "args": {},
      "expect": {
        "containsAny": ["Spaced Repetition", "cancip.study.review", "flashcards", "review"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.currentView",
      "command": "obsidian.currentView",
      "args": { "includeText": false, "visibleChars": 600 },
      "expect": {
        "containsAny": ["viewType", "activeFile", "leaf"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.findTarget.daily-note",
      "command": "cancip.findTarget",
      "args": { "query": "打开今日日记", "limit": 8 },
      "expect": {
        "contains": ["Target discovery", "Obsidian command fuzzy match", "next:"],
        "containsAny": ["daily-notes", "日记", "daily"],
        "maxMs": 5000
      }
    },
    {
      "id": "command.obsidian.listCommands",
      "command": "obsidian.listCommands",
      "args": { "query": "file", "limit": 20 },
      "expect": {
        "containsAny": ["file", "open", "command", "命令"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.js.help",
      "command": "obsidian.js.help",
      "args": {},
      "expect": {
        "contains": ["Obsidian JS bridge", "helpers.plugin", "obsidian.eval"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.js.probe",
      "command": "obsidian.js.probe",
      "args": { "maxPlugins": 8 },
      "expect": {
        "contains": ["Obsidian JS bridge probe", "loadedPlugins", "methods"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.eval.expression",
      "command": "obsidian.eval",
      "args": { "expression": "({activeFile: app.workspace.getActiveFile()?.path || '', pluginCount: Object.keys(plugins).length, commandCount: Object.keys(app.commands.commands).length})", "maxChars": 1200 },
      "expect": {
        "contains": ["Obsidian JS bridge", "pluginCount", "commandCount"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.eval.alias-js",
      "command": "js.eval",
      "args": { "code": "return helpers.snapshot();", "maxChars": 1200 },
      "expect": {
        "contains": ["Obsidian JS bridge", "pluginCount", "commandCount"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.fuzzy",
      "command": "obsidian.resolveCommand",
      "args": { "query": "open command palette" },
      "expect": {
        "contains": ["Resolved: command-palette:open"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.daily-note",
      "command": "obsidian.resolveCommand",
      "args": { "query": "open today's daily note" },
      "expect": {
        "contains": ["Resolved: daily-notes"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.notedraw-intent",
      "command": "obsidian.resolveCommand",
      "args": { "query": "notedraw 涂鸦 高亮" },
      "expect": {
        "contains": ["Resolved: notedraw:toggle-draw-mode"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.spaced-repetition",
      "command": "obsidian.resolveCommand",
      "args": { "query": "spaced repetition review flashcards in note" },
      "expect": {
        "contains": ["spaced"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.mobile-pdf",
      "command": "obsidian.resolveCommand",
      "args": { "query": "移动端导出pdf" },
      "expect": {
        "contains": ["Resolved: mobile-pdf-exporter:export-current-note-preview-pdf"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.excalidraw-sidepanel",
      "command": "obsidian.resolveCommand",
      "args": { "query": "excalidraw 打开侧边面板" },
      "expect": {
        "contains": ["Resolved: obsidian-excalidraw-plugin:excalidraw-open-sidepanel"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.tasks-edit",
      "command": "obsidian.resolveCommand",
      "args": { "query": "tasks edit task" },
      "expect": {
        "contains": ["Resolved: obsidian-tasks-plugin:edit-task"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.resolveCommand.dataview-refresh",
      "command": "obsidian.resolveCommand",
      "args": { "query": "dataview refresh" },
      "expect": {
        "contains": ["Resolved: dataview:dataview-force-refresh-views"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.execute.exact",
      "command": "obsidian.execute",
      "args": { "id": "editor:save-file" },
      "expect": {
        "contains": ["executed: editor:save-file"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.obsidian.execute.direct-id",
      "command": "editor:save-file",
      "args": {},
      "expect": {
        "contains": ["executed: editor:save-file"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.automation.templates",
      "command": "cancip.automation.templates",
      "args": {},
      "expect": {
        "contains": ["自动化模板"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.automation.list",
      "command": "cancip.automation.list",
      "args": {},
      "expect": {
        "containsAny": ["自动化", "automation", "任务", "none"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.attachment.help",
      "command": "cancip.attachment.help",
      "args": {},
      "expect": {
        "containsAny": ["PDF", "Excel", "attachment", "附件", "share"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.externalFiles.help",
      "command": "cancip.externalFiles.help",
      "args": {},
      "expect": {
        "containsAny": ["external", "库外", "文件", "bridge", "附件"],
        "maxMs": 3000
      }
    },
    {
      "id": "command.subagents.list",
      "command": "cancip.subagents.list",
      "args": {},
      "expect": {
        "containsAny": ["子 agent", "subagent", "没有子 agent", "No subagents"],
        "maxMs": 3000
      }
    }
  ],
  "writeCases": [
    {
      "id": "write.vault.temp-note",
      "action": {
        "type": "write",
        "path": ".cancip/test-lab/smoke-note.md",
        "content": "# Cancip Smoke Note\n\nThis file is created by the optional smoke test and can be deleted."
      },
      "verify": {
        "action": { "type": "read", "path": ".cancip/test-lab/smoke-note.md", "maxChars": 1000 },
        "contains": ["Cancip Smoke Note"]
      }
    },
    {
      "id": "write.config.temp-json",
      "action": {
        "type": "config",
        "path": ".cancip/test-lab/smoke-config.json",
        "set": {
          "smoke": {
            "ok": true,
            "source": "scripts/run-cancip-smoke.mjs"
          }
        }
      },
      "verify": {
        "action": { "type": "read", "path": ".cancip/test-lab/smoke-config.json", "maxChars": 1000 },
        "contains": ["\"ok\": true"]
      }
    },
    {
      "id": "write.cleanup",
      "action": { "type": "delete", "path": ".cancip/test-lab", "permanent": false },
      "optional": true
    }
  ]
}
